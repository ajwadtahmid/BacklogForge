# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# URL of the BacklogForge backend (no trailing slash).
BACKEND_URL=https://yourserver.com
# Shared secret between the app and the /user/library endpoint.
# Set the same value as CLIENT_TOKEN on your server.
# Leave blank to disable auth (self-hosted deployments without a token).
CLIENT_TOKEN=
